---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import PublicationItem from "../components/PublicationItem.astro";
import { getCollection } from "astro:content";
import { byOrder, byYearDesc, siteConfig } from "../lib/site";

const publications = (await getCollection("publications")).sort(byYearDesc);
const mediaCoverage = (await getCollection("media")).sort(byOrder);

const byYear = publications.reduce<Record<number, typeof publications>>(
  (acc, pub) => {
    const year = pub.data.year;
    if (!acc[year]) acc[year] = [];
    acc[year].push(pub);
    return acc;
  },
  {},
);

const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout
  title="Publications | Qasim Lab"
  description="Publications from the Qasim Lab on memory, mental health, and intracranial neuroscience."
>
  <Section>
    <SectionHeading
      eyebrow="Publications"
      title="What have we published?"
      intro="Peer-reviewed papers from the lab, grouped by year. For a complete list, see our Google Scholar profile."
    />
    <p class="mb-10">
      <a
        href={siteConfig.contact.scholar}
        class="text-sm font-medium text-accent hover:underline"
        target="_blank"
        rel="noopener noreferrer"
      >
        View all publications on Google Scholar &rarr;
      </a>
    </p>

    {
      mediaCoverage.length > 0 && (
        <div class="mb-16 rounded-xl border border-border bg-surface p-8">
          <h3 class="font-display text-2xl font-semibold text-foreground">
            Media coverage
          </h3>
          <ul class="mt-6 space-y-4">
            {mediaCoverage.map((entry) => (
              <li>
                <a
                  href={entry.data.link}
                  class="font-medium text-foreground hover:text-accent"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {entry.data.title}
                </a>
                <span class="text-sm text-muted">
                  {" "}
                  — {entry.data.outlet}
                  {entry.data.year ? `, ${entry.data.year}` : ""}
                </span>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      years.map((year) => (
        <div class="mb-12">
          <h3 class="mb-4 font-display text-2xl font-semibold text-foreground">
            {year}
          </h3>
          <div>
            {byYear[year].map((entry) => (
              <PublicationItem
                title={entry.data.title}
                authors={entry.data.authors}
                journal={entry.data.journal}
                year={entry.data.year}
                link={entry.data.link}
              />
            ))}
          </div>
        </div>
      ))
    }
  </Section>
</BaseLayout>
