---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Card from "../components/Card.astro";
import Button from "../components/Button.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../lib/site";

const positions = await getCollection("positions");
const openPositions = positions
  .filter((p) => p.data.open)
  .filter((p) => p.data.type !== "Postdoc");
---

<BaseLayout
  title="Join the Lab | Qasim Lab"
  description="Open positions and how to apply to join the Qasim Lab at Rutgers University."
>
  <Section>
    <SectionHeading
      eyebrow="Join"
      title="Want to join the lab?"
      intro="We study the mental computations that make memories sticky — and how those processes go awry in memory loss and mental health disorders."
    />

    <div class="prose-content mb-16 max-w-3xl">
      <p>
        The Qasim Lab at Rutgers Robert Wood Johnson Medical School uses
        intracranial electrophysiology, computational modeling, and behavioral
        experiments to understand how memories are encoded, strengthened, and
        retrieved — and what goes wrong when those mechanisms fail.
      </p>
      <p>
        We welcome undergraduates and PhD candidates from diverse backgrounds
        including neuroscience, psychology, computer science, and engineering.
        PhD students typically apply through Rutgers graduate programs in
        Neuroscience or Psychology. Undergraduates should email the PI with a
        CV and statement of interest.
      </p>
    </div>

    <h3 class="mb-6 font-display text-2xl font-semibold text-foreground">
      Open positions
    </h3>

    {
      openPositions.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2">
          {openPositions.map((entry) => (
            <Card>
              <span class="text-sm font-medium text-accent">{entry.data.type}</span>
              <h4 class="mt-2 font-display text-xl font-semibold text-foreground">
                {entry.data.title}
              </h4>
              <p class="mt-3 text-sm leading-relaxed text-muted">
                {entry.data.description}
              </p>
            </Card>
          ))}
        </div>
      ) : (
        <p class="text-muted">
          We do not have open positions at this time, but we encourage
          prospective students to apply through Rutgers graduate programs.
        </p>
      )
    }

    <div class="mt-12 rounded-xl border border-border bg-surface p-8">
      <h3 class="font-display text-xl font-semibold text-foreground">
        How to apply
      </h3>
      <ul class="mt-4 space-y-2 text-muted">
        <li>
          <strong class="text-foreground">PhD candidates:</strong> Apply through the
          Rutgers graduate program and mention the Qasim Lab in your statement.
        </li>
        <li>
          <strong class="text-foreground">Undergraduates:</strong> Email{" "}
          <a
            href={`mailto:${siteConfig.contact.email}`}
            class="text-accent hover:underline"
          >
            {siteConfig.contact.email}
          </a>{" "}
          with your CV and a brief statement of interest.
        </li>
      </ul>
      <div class="mt-6">
        <Button href={`mailto:${siteConfig.contact.email}`}>
          Get in touch
        </Button>
      </div>
    </div>
  </Section>
</BaseLayout>
