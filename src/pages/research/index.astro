---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ResearchCard from "../../components/ResearchCard.astro";
import { getCollection } from "astro:content";
import { byOrder } from "../../lib/site";

const research = (await getCollection("research")).sort(byOrder);
---

<BaseLayout
  title="Research | Qasim Lab"
  description="Research areas in the Qasim Lab: direct brain recordings, memory and spatial cognition, memory persistence and mental health, and computational methods."
>
  <Section>
    <SectionHeading
      eyebrow="Research"
      title="What makes memories stick?"
      intro="We investigate the mental computations that encode, strengthen, and retrieve memories — and how those processes go awry in memory loss and mental health disorders."
    />
    <div class="grid gap-6 md:grid-cols-2">
      {
        research.map((entry) => (
          <ResearchCard
            title={entry.data.title}
            summary={entry.data.summary}
            slug={entry.id}
          />
        ))
      }
    </div>
  </Section>
</BaseLayout>
