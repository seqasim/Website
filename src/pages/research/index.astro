---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ResearchCard from "../../components/ResearchCard.astro";
import { getCollection } from "astro:content";
import { byOrder } from "../../lib/site";

const research = (await getCollection("research")).sort(byOrder);
---

<BaseLayout
  title="Research | Qasim Lab"
  description="Research areas in the Qasim Lab: direct brain recordings, memory and spatial cognition, emotion and decision-making, and computational methods."
>
  <Section>
    <SectionHeading
      eyebrow="Research"
      title="What does the lab study?"
      intro="We investigate biomarkers of complex cognitive function and dysfunction using direct-brain recordings in human neurosurgical patients, leveraging neural engineering, computational models, and statistical analysis of neural data."
    />
    <div class="grid gap-6 md:grid-cols-2">
      {
        research.map((entry) => (
          <ResearchCard
            title={entry.data.title}
            summary={entry.data.summary}
            slug={entry.id}
          />
        ))
      }
    </div>
  </Section>
</BaseLayout>
