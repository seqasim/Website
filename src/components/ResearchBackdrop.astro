---
/**
 * Soft photographic backdrop for homepage sections.
 * Uses licensed / lab science photographs — not generated graphics.
 */
import { withBase } from "../lib/site";

interface Props {
  /** Image path under public/, e.g. /images/backdrops/eeg-traces-blue.jpg */
  src?: string;
  /** Softer opacity / corner placement for secondary placements. */
  density?: "full" | "echo";
  class?: string;
  /** CSS object-position for the photo crop. */
  position?: string;
}

const {
  src = "/images/backdrops/eeg-traces-blue.jpg",
  density = "full",
  class: className = "",
  position = "center",
} = Astro.props;

const opacity = density === "full" ? "opacity-[0.28]" : "opacity-[0.20]";
const maskClass =
  density === "full"
    ? "[mask-image:radial-gradient(120%_110%_at_50%_45%,#000_45%,transparent)]"
    : "[mask-image:radial-gradient(90%_90%_at_85%_70%,#000_35%,transparent)]";
---

<div
  class:list={[
    "pointer-events-none absolute overflow-hidden",
    density === "full" && "inset-0",
    maskClass,
    className,
  ]}
  aria-hidden="true"
>
  <img
    src={withBase(src)}
    alt=""
    class:list={["h-full w-full object-cover", opacity]}
    style={`object-position: ${position}`}
    loading="lazy"
    decoding="async"
  />
</div>
