---
/**
 * Lab icons from the licensed Adobe Stock "Brain Icons" pack
 * (AdobeStock_718653205), tinted to ink teal and served as PNGs.
 */
import { withBase } from "../lib/site";
import { resolveIconName, type IconName } from "../lib/icons";

interface Props {
  name: IconName;
  size?: number;
  class?: string;
}

const { name, size = 28, class: className = "" } = Astro.props;
const resolved = resolveIconName(name);
const src = withBase(`/images/icons/${resolved}.png`);
---

<img
  src={src}
  width={size}
  height={size}
  alt=""
  aria-hidden="true"
  class:list={["object-contain", className]}
  loading="lazy"
  decoding="async"
/>
