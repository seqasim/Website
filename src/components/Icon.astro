---
/**
 * Minimalist neuroscience line icons.
 * Stroke uses currentColor so icons inherit text/ink color from parents.
 */
interface Props {
  name:
    | "electrode"
    | "grid"
    | "network"
    | "function"
    | "sticky"
    | "fade"
    | "mental-health";
  size?: number;
  class?: string;
}

const { name, size = 28, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {
    name === "electrode" && (
      <>
        <path d="M8 4v12" />
        <circle cx="8" cy="18" r="2" />
        <path d="M12 8h2.5l2 4 2.5-8 2 5H22" />
      </>
    )
  }
  {
    name === "grid" && (
      <>
        <path d="M12 3.5 18 7v6.5L12 17.5 6 13.5V7z" />
        <path d="M12 3.5V17.5" />
        <path d="M6 7l6 3.5L18 7" />
        <circle cx="12" cy="10.5" r="1.2" fill="currentColor" stroke="none" />
      </>
    )
  }
  {
    name === "network" && (
      <>
        <circle cx="6" cy="7" r="2" />
        <circle cx="18" cy="7" r="2" />
        <circle cx="12" cy="17" r="2" />
        <circle cx="12" cy="10" r="1.5" />
        <path d="M7.7 8.2 10.5 9.5" />
        <path d="M13.5 9.5 16.3 8.2" />
        <path d="M12 11.5v3.5" />
        <path d="M7.5 8.5 11 16" />
        <path d="M16.5 8.5 13 16" />
      </>
    )
  }
  {
    name === "function" && (
      <>
        <path d="M4 18c2-8 4-10 6-6s3 10 5 6 3-10 5-6" />
        <path d="M4 4v16h16" />
      </>
    )
  }
  {
    name === "sticky" && (
      <>
        <path d="M12 5a5 5 0 1 1-3.5 8.5" />
        <path d="M12 5v5.5a1.5 1.5 0 0 0 1.5 1.5H19" />
        <circle cx="12" cy="18.5" r="1.5" fill="currentColor" stroke="none" />
        <path d="M12 15.5v1.5" />
      </>
    )
  }
  {
    name === "fade" && (
      <>
        <circle cx="12" cy="12" r="3" />
        <path d="M7.5 7.5a6.5 6.5 0 0 1 9 0" stroke-dasharray="2 2.5" />
        <path
          d="M5 5a10 10 0 0 1 14 0"
          stroke-dasharray="2 3"
          opacity="0.6"
        />
        <path
          d="M16.5 16.5a6.5 6.5 0 0 1-9 0"
          stroke-dasharray="2 2.5"
          opacity="0.5"
        />
      </>
    )
  }
  {
    name === "mental-health" && (
      <>
        <path d="M12 20s-7-4.5-7-10a4 4 0 0 1 7-2.5A4 4 0 0 1 19 10c0 5.5-7 10-7 10z" />
        <path d="M9.5 11.5c.5 1.5 1.5 2.5 2.5 3 1-.5 2-1.5 2.5-3" />
      </>
    )
  }
</svg>
