---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  class?: string;
}

const { eyebrow, title, intro, class: className = "" } = Astro.props;
---

<div class:list={["mb-10 md:mb-12", className]}>
  {eyebrow && (
    <p class="mb-2 text-sm font-medium uppercase tracking-wider text-accent">
      {eyebrow}
    </p>
  )}
  <h2 class="font-display text-3xl font-semibold text-foreground md:text-4xl">
    {title}
  </h2>
  {intro && (
    <p class="mt-4 max-w-2xl text-lg text-muted">{intro}</p>
  )}
</div>
