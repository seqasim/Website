---
import Card from "./Card.astro";
import Icon from "./Icon.astro";
import { withBase } from "../lib/site";

interface Props {
  title: string;
  summary: string;
  slug: string;
  icon?:
    | "electrode"
    | "grid"
    | "network"
    | "function"
    | "sticky"
    | "fade"
    | "mental-health";
}

const { title, summary, slug, icon } = Astro.props;
---

<Card class="group h-full">
  <a href={withBase(`/research/${slug}`)} class="block h-full">
    {
      icon && (
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-ink-soft text-ink transition-colors group-hover:bg-ink/15">
          <Icon name={icon} size={22} />
        </div>
      )
    }
    <h3 class="font-display text-xl font-semibold text-foreground group-hover:text-accent">
      {title}
    </h3>
    <p class="mt-3 text-sm leading-relaxed text-muted">{summary}</p>
    <span class="mt-4 inline-block text-sm font-medium text-accent">
      Learn more &rarr;
    </span>
  </a>
</Card>
