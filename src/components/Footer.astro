---
import { navLinks, siteConfig, withBase } from "../lib/site";
---

<footer class="border-t border-border bg-surface">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <p class="font-display text-lg font-semibold text-foreground">
          {siteConfig.name}
        </p>
        <p class="mt-2 text-sm text-muted">{siteConfig.institution}</p>
        <p class="mt-1 text-sm text-muted">{siteConfig.contact.address}</p>
      </div>

      <div>
        <p class="text-sm font-medium text-foreground">Navigation</p>
        <ul class="mt-3 space-y-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={withBase(link.href)}
                  class="text-sm text-muted hover:text-accent"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <p class="text-sm font-medium text-foreground">Contact</p>
        <ul class="mt-3 space-y-2">
          <li>
            <a
              href={`mailto:${siteConfig.contact.email}`}
              class="text-sm text-muted hover:text-accent"
            >
              {siteConfig.contact.email}
            </a>
          </li>
          <li>
            <a
              href={siteConfig.contact.github}
              class="text-sm text-muted hover:text-accent"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href={siteConfig.contact.twitter}
              class="text-sm text-muted hover:text-accent"
              target="_blank"
              rel="noopener noreferrer"
            >
              X (Twitter)
            </a>
          </li>
          <li>
            <a
              href={siteConfig.contact.scholar}
              class="text-sm text-muted hover:text-accent"
              target="_blank"
              rel="noopener noreferrer"
            >
              Google Scholar
            </a>
          </li>
          <li>
            <a
              href={siteConfig.contact.labSite}
              class="text-sm text-muted hover:text-accent"
              target="_blank"
              rel="noopener noreferrer"
            >
              Rutgers Lab Site
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-border pt-8">
      <p class="text-sm text-muted">
        &copy; {new Date().getFullYear()} {siteConfig.name}, {siteConfig.institution}
      </p>
    </div>
  </div>
</footer>
