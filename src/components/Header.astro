---
import { navLinks, siteConfig, withBase } from "../lib/site";

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname
  .replace(base, "/")
  .replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-40 border-b border-border bg-background/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a
      href={withBase("/")}
      class="font-display text-xl font-semibold text-foreground hover:text-accent"
    >
      {siteConfig.name}
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {
        navLinks.map((link) => (
          <a
            href={withBase(link.href)}
            class:list={[
              "text-sm font-medium uppercase tracking-wide transition-colors hover:text-ink",
              currentPath === link.href || currentPath.startsWith(`${link.href}/`)
                ? "text-ink"
                : "text-muted",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile nav -->
    <details class="relative md:hidden">
      <summary
        class="cursor-pointer list-none rounded-md p-2 text-foreground hover:bg-surface [&::-webkit-details-marker]:hidden"
        aria-label="Toggle menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </summary>
      <nav
        class="absolute right-0 top-full mt-2 w-48 rounded-xl border border-border bg-background py-2 shadow-sm"
        aria-label="Mobile navigation"
      >
        {
          navLinks.map((link) => (
            <a
              href={withBase(link.href)}
              class:list={[
                "block px-4 py-2 text-sm font-medium uppercase tracking-wide transition-colors hover:bg-surface hover:text-ink",
                currentPath === link.href || currentPath.startsWith(`${link.href}/`)
                  ? "text-ink"
                  : "text-foreground",
              ]}
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </details>
  </div>
</header>
